{
    "label" : "lock",
    "action" : "swaylock -f -C $HOME/.config/swaylock/config",
    "text" : "Lock",
    "keybind" : "l",
    "height" : 0.82,
    "width" : 0.5
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u",
    "height" : 0.82,
    "width" : 0.5
}
{
    "label" : "logout",
    "action" : "mmsg dispatch quit",
    "text" : "Logout",
    "keybind" : "e",
    "height" : 0.82,
    "width" : 0.5
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s",
    "height" : 0.82,
    "width" : 0.5
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r",
    "height" : 0.82,
    "width" : 0.5
}
