{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/minimax-m3",
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 51500,
  },
  "command": {
    "research": {
      "description": "Use the research agent for codebase or documentation exploration",
      "agent": "explore",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "subtask": true,
      "template": "Research this thoroughly and return concise findings with relevant file paths, commands, URLs, or source notes: Provide thorough, detailed responses that explore topics from multiple angles. Include relevant context, examples, nuances, and implications. Structure information clearly with appropriate depth, covering edge cases and related considerations. Aim for completeness while maintaining clarity and organization.",
    },
    "reverse": {
      "description": "Reverse engineer code behavior, architecture, data flow, and implementation details",
      "agent": "explore",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "subtask": true,
      "template": "Reverse engineer this target in read-only mode. Focus on architecture, entrypoints, data flow, control flow, important abstractions, hidden assumptions, invariants, security-sensitive behavior, and implementation notes. Return concise findings with file paths and line references where possible.",
    },
    "review": {
      "description": "Review changes for bugs, regressions, and missing tests",
      "agent": "plan",
      "template": "Review the relevant changes. Prioritize bugs, behavioral regressions, security issues, and missing tests. Lead with findings and include file/line references when available.",
    },
  },
  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "high",
      "steps": 40,
    },
    "plan": {
      "model": "github-copilot/gpt-5.5",
      "variant": "xhigh",
      "steps": 12,
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "steps": 24,
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "steps": 20,
    },
    "summary": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium",
      "steps": 2,
    },
    "compaction": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium",
      "steps": 3,
    },
    "title": {
      "model": "opencode-go/minimax-m3",
      "variant": "none",
      "steps": 1,
    },
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6,
  },
}
