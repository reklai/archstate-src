#!/usr/bin/env bash
set -euo pipefail

BATTERY_PATH="${BATTERY_PATH:-/sys/class/power_supply/BAT0}"
LOW_THRESHOLD="${LOW_THRESHOLD:-40}"
HIGH_THRESHOLD="${HIGH_THRESHOLD:-60}"
STATE_DIR="${STATE_DIR:-/var/lib/battery-charge-probe}"
STATE_FILE="${STATE_FILE:-$STATE_DIR/state}"

die() {
  printf 'battery-charge-probe: %s\n' "$*" >&2
  exit 1
}

is_uint() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

is_uint "$LOW_THRESHOLD" || die "LOW_THRESHOLD must be an integer"
is_uint "$HIGH_THRESHOLD" || die "HIGH_THRESHOLD must be an integer"

if (( LOW_THRESHOLD < 1 || HIGH_THRESHOLD > 100 || LOW_THRESHOLD >= HIGH_THRESHOLD )); then
  die "invalid thresholds: low=$LOW_THRESHOLD high=$HIGH_THRESHOLD"
fi

capacity_file="$BATTERY_PATH/capacity"
threshold_file="$BATTERY_PATH/charge_control_end_threshold"

[[ -r "$capacity_file" ]] || die "cannot read $capacity_file"
[[ -e "$threshold_file" ]] || die "missing $threshold_file"

IFS= read -r capacity < "$capacity_file"
is_uint "$capacity" || die "invalid battery capacity: $capacity"

install -d -m 0755 "$STATE_DIR"
exec 9>"$STATE_DIR/lock"
flock -n 9 || exit 0

state=""
if [[ -r "$STATE_FILE" ]]; then
  IFS= read -r state < "$STATE_FILE" || true
fi

case "$state" in
  charging|holding)
    ;;
  *)
    if (( capacity <= LOW_THRESHOLD )); then
      state="charging"
    else
      state="holding"
    fi
    ;;
esac

if (( capacity <= LOW_THRESHOLD )); then
  state="charging"
elif (( capacity >= HIGH_THRESHOLD )); then
  state="holding"
fi

case "$state" in
  charging)
    target="$HIGH_THRESHOLD"
    ;;
  holding)
    target="$LOW_THRESHOLD"
    ;;
  *)
    die "invalid state: $state"
    ;;
esac

current="$(cat "$threshold_file" 2>/dev/null || true)"
if [[ "$current" != "$target" ]]; then
  printf '%s\n' "$target" > "$threshold_file"
  changed="yes"
else
  changed="no"
fi

tmp_state="$(mktemp "$STATE_DIR/state.XXXXXX")"
printf '%s\n' "$state" > "$tmp_state"
chmod 0644 "$tmp_state"
mv "$tmp_state" "$STATE_FILE"

printf 'capacity=%s low=%s high=%s state=%s threshold=%s previous_threshold=%s changed=%s\n' \
  "$capacity" "$LOW_THRESHOLD" "$HIGH_THRESHOLD" "$state" "$target" "${current:-unknown}" "$changed"
